{
  "name": "simple-checkout-style-tealer",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "A minimal single-page TagadaPay checkout plugin with a streetwear / neobrutalist aesthetic built for CBD, streetwear and urban commerce brands (acid-lime neon palette, Archivo Black + Space Grotesk + JetBrains Mono, 2px black borders, hard drop shadows, pilled CTAs). Uses the exact hook-level behavior of the production native-checkout — reference implementation of @tagadapay/plugin-sdk v2.",
  "scripts": {
    "dev": "echo '🔥 Starting simple-checkout-style-tealer...' && echo '📱 Plugin will open at http://localhost:5173' && vite",
    "dev:local-sdk": "echo '🔧 Using local SDK for development...' && VITE_SDK_MODE=local vite",
    "dev:fast": "vite --force",
    "build": "tsc && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "zip": "npm run build && cd dist && zip -r ../plugin.zip .",
    "deploy": "npm run build && tgdcli deploy --verbose",
    "deploy:dev": "npm run build && tgdcli deploy --dev --verbose",
    "deploy:staging": "npm run build && tgdcli deploy --staging --verbose",
    "deploy:prod": "npm run build && tgdcli deploy --prod --verbose"
  },
  "dependencies": {
    "@basis-theory/apple-pay-js": "^2.0.3",
    "@basis-theory/basis-theory-js": "^4.30.0",
    "@basis-theory/basis-theory-react": "^1.32.5",
    "@basis-theory/web-threeds": "^1.0.1",
    "@google-pay/button-react": "^3.2.1",
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-checkbox": "1.1.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "2.1.1",
    "@radix-ui/react-radio-group": "1.2.2",
    "@radix-ui/react-select": "2.1.4",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slot": "1.1.1",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@remixicon/react": "^4.2.0",
    "@tagadapay/plugin-sdk": "^2.3.0",
    "@tanstack/react-query": "^5.90.5",
    "axios": "^1.12.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.23.24",
    "libphonenumber-js": "^1.11.17",
    "lucide-react": "^0.454.0",
    "react": "^19",
    "react-dom": "^19",
    "react-hook-form": "^7.60.0",
    "react-hot-toast": "^2.5.2",
    "react-intl": "^7.1.14",
    "react-loading-skeleton": "^3.5.0",
    "react-markdown": "^10.1.0",
    "react-number-format": "^5.4.4",
    "swr": "^2.3.6",
    "tailwind-merge": "^2.5.5",
    "tailwind-variants": "^1.0.0",
    "tailwindcss-animate": "^1.0.7",
    "tw-animate-css": "^1.3.7",
    "wouter": "^3.7.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "@tagadapay/plugin-cli": "^2.0.19",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@typescript-eslint/eslint-plugin": "^8.15.0",
    "@typescript-eslint/parser": "^8.15.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.15.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "globals": "^15.12.0",
    "postcss": "^8.5",
    "tailwindcss": "^3.4.0",
    "typescript": "^5",
    "typescript-eslint": "^8.35.1",
    "vite": "^6.0.3"
  }
}
