{
  "name": "Simple Checkout — Arcade / Y2K",
  "pluginId": "simple-checkout-style-arcade",
  "description": "A minimal single-page TagadaPay checkout plugin with a Y2K / retro-arcade aesthetic (soft lavender + hot peach + electric blue + deep plum, Reckless Neue + General Sans + JetBrains Mono, chunky pill CTAs, inner-glow candy cards, soft holo gradient accent, 140ms overshoot motion). Built for gaming merch, Gen-Z beauty, music merch, subscription beauty. Uses the same @tagadapay/plugin-sdk v2 hooks as the production native-checkout.",
  "version": "1.0.0",
  "author": "TagadaPay Team",
  "mode": "direct-mode",
  "category": "checkout",
  "tags": ["checkout", "example", "v2", "payment", "single-step", "y2k", "arcade", "gen-z", "beauty", "gaming"],
  "configuration": {
    "schema": "./config/schema.json",
    "uiSchema": "./config/ui-schema.json",
    "presets": [
      {
        "id": "default",
        "name": "Arcade Default",
        "description": "Soft lavender + hot peach + electric blue — Y2K candy checkout.",
        "config": "./config/default.config.json"
      }
    ]
  },
  "pages": [
    {
      "path": "/checkout",
      "features": [
        {
          "type": "checkout",
          "requirements": [
            {
              "resource": "checkoutSession",
              "from": [
                {
                  "name": "checkoutToken",
                  "type": "query",
                  "required": false
                },
                {
                  "name": "checkoutToken",
                  "type": "context",
                  "required": false
                }
              ]
            }
          ]
        }
      ],
      "remappable": true
    },
    {
      "path": "/thankyou/:orderId",
      "features": [
        {
          "type": "thankyou",
          "requirements": [
            {
              "resource": "order",
              "from": [
                {
                  "name": "id",
                  "type": "path"
                }
              ]
            }
          ]
        }
      ],
      "remappable": true
    }
  ],
  "router": {
    "basePath": "/",
    "matcher": ".*",
    "excluder": null
  },
  "requirements": {
    "sdk": "^2.2.0",
    "sdkVersion": "v2"
  }
}
